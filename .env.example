# ─── Server ───────────────────────────────────────────────
PORT=8080
ENV=development

# ─── Supabase/PostgreSQL ──────────────────────────────────
SUPABASE_DATABASE_URL=
# ─── JWT (self-signed, HS256) ─────────────────────────────
JWT_SECRET=

# ─── OAuth — Google ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth — GitHub ───────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=

# ─── CORS / OAuth ────────────────────────────────────────
FRONTEND_URL=http://localhost:300

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=text